<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 27+ overrides: windowLightNavigationBar requires API 27 -->
    <style name="Theme.ZBrowser" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/browser_toolbar_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/browser_toolbar_bg</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
